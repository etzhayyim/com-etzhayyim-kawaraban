          "name" : {
            "type" : "string"
          },
          "country" : {
            "type" : "string"
          },
          "lang" : {
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          },
          "kind" : {
            "type" : "string",
            "enum" : [ "public-broadcaster", "wire-agency", "newspaper", "magazine", "digital-native", "ngo-press" ]
          },
          "homepage" : {
            "type" : "string"
          },
          "access" : {
            "type" : "string",
            "enum" : [ "open", "registration-wall" ],
