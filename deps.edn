{:paths ["src" "test"]
 ;; ADR-2607110200: kawaraban's first .clj (JVM-only I/O) files — cacao.clj (Ed25519/CACAO
 ;; mint) and aozora.clj (aozora PDS publish) — need real JDK crypto, unlike the portable
 ;; .cljc methods/cells exercised by the standalone Clojure test runner. Same split as tashikame's
 ;; deps.edn (its closest sibling: identical cacao/aozora/publisher shape).
 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        org.clojure/data.json {:mvn/version "2.5.1"}
        ;; Phase G (com-junkawasaki/root): promoted out of the :test alias's
        ;; :extra-deps below -- `src/kawaraban/wasm_orchestrator.clj` hosts
        ;; wasm/*.wasm (compiled from wasm/*.kotoba, see wasm/README.md) via
        ;; kototama.tender as a REAL runtime path now (the :wasm-orchestrator
        ;; alias's `-main`, invoked from launchd -- see
        ;; scripts/launchd/com.etzhayyim.kawaraban.wasm-orchestrator.plist),
        ;; not merely from tests. Pinned to the SAME kotoba-lang/kototama
        ;; sha the :test alias already required (post-PR#50, http-post-headers
        ;; + cbor/json dotted-path nesting, ADR-2607231234 "Phase E") -- kept
        ;; as ONE pin, not two, now that both :deps and :test need it.
        io.github.kotoba-lang/kototama
        {:git/sha "38613c0808dbb27c782b616299138ec687509f2b"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]}
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main" "--lint" "src" "test" "--fail-level" "error"]}
  :live-ingest {:main-opts ["-m" "kawaraban.run-live-ingest"]}
  ;; Phase G (com-junkawasaki/root): the wasm-path orchestrator's own
  ;; entrypoint (fetch -> G1/G3/G4/G8 gate -> per-outlet identity + CACAO
  ;; sign + aozora XRPC publish, all via kotoba-wasm/kototama.tender --
  ;; see src/kawaraban/wasm_orchestrator.clj's own namespace docstring).
  ;; Invoked by scripts/launchd/com.etzhayyim.kawaraban.wasm-orchestrator.plist.
  :wasm-orchestrator {:main-opts ["-m" "kawaraban.wasm-orchestrator"]}}}
