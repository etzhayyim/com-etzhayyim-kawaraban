{:paths ["src" "test"]
 ;; ADR-2607110200: kawaraban's first .clj (JVM-only I/O) files — cacao.clj (Ed25519/CACAO
 ;; mint) and aozora.clj (aozora PDS publish) — need real JDK crypto, unlike the portable
 ;; .cljc methods/cells exercised by the standalone Clojure test runner. Same split as tashikame's
 ;; deps.edn (its closest sibling: identical cacao/aozora/publisher shape).
 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        org.clojure/data.json {:mvn/version "2.5.1"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                      ;; test-only: hosts wasm/*.wasm (compiled from
                      ;; wasm/*.kotoba, see wasm/README.md) via
                      ;; kototama.tender -- proves the kotoba-wasm
                      ;; componentization of kawaraban.cacao/kawaraban.aozora
                      ;; runs as a real Chicory-hosted WASM guest, not just as
                      ;; JVM Clojure. Pinned to kotoba-lang/kototama main
                      ;; post-PR#49 (http-fetch/cbor-encode/json-encode/
                      ;; json-extract-field capabilities, ADR-2607231022).
                      ;; Same test-only local/root convention
                      ;; cloud-itonami-isic-6310's deps.edn established for
                      ;; this exact pattern -- git/sha here instead of
                      ;; local/root since this repo is not west-managed
                      ;; alongside kotoba-lang/kototama.
                      io.github.kotoba-lang/kototama
                      {:git/sha "0ccdafc6f2c5cff91c5a02f7bc4845778fcdacee"}}
         :main-opts ["-m" "cognitect.test-runner"]}
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main" "--lint" "src" "test" "--fail-level" "error"]}
  :live-ingest {:main-opts ["-m" "kawaraban.run-live-ingest"]}}}
