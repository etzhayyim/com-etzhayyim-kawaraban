{:paths ["src" "test"]
 ;; ADR-2607110200: kawaraban's first .clj (JVM-only I/O) files — cacao.clj (Ed25519/CACAO
 ;; mint) and aozora.clj (aozora PDS publish) — need real JDK crypto, unlike the portable
 ;; .cljc methods/cells exercised by the standalone Clojure test runner. Same split as tashikame's
 ;; deps.edn (its closest sibling: identical cacao/aozora/publisher shape).
 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        org.clojure/data.json {:mvn/version "2.5.1"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]}
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main" "--lint" "src" "test" "--fail-level" "error"]}
  :live-ingest {:main-opts ["-m" "kawaraban.run-live-ingest"]}}}
