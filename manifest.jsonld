    ]
  },
  "scope": {
    "phase": "R0 — ontology (00-contracts/schemas/news-medium-ontology.kotoba.edn) + 6 lexicons + 5 cells (ALL coded state machines: outlet_ingest / article_mirror / section_route / actor_project / issue_compose; every .solve() RuntimeError at R0 — live ingest/publish is G8-gated) + connective-medium routing engine (methods/route.py — the actor→面 wire table + article×mention×面 graph builder) + issue composer (methods/analyze.py — ranks a front-面 by G2 public-good signals only, emits an edition + 面 distribution + the actor-to-actor connection graph) + offline outlet normalizer (methods/ingest.py — G4 membrane refuses full-text + paywall, G8 --live gated) + kotoba-wasm WIT contract + Murakumo fleet placement + :representative seed (7 outlets / 10 面 / 12 articles / 9 actor-wires / 24 mention edges). Registered in INFRA_ACTORS → did:web:etzhayyim.com:actor:kawaraban. Design + datafication + offline composition only; NO live RSS/outlet ingest, NO live publish.",
    "scopeBoundary": "Mirror real news media into kotoba (link-out, no full text, no verdict) + wire first-party actor Datom events into the matching 面 as the actor-to-actor medium (design-only)",
    "exclusions": [
      "adjudicating truth / fact-check score (G1, N1) — ake/danjo boundary",
      "advertising / paid-placement / sponsored / engagement-ranking (G2, N2)",
      "per-reader profile / behavioral recommendation / reader surveillance (G3, N3)",
      "republishing full copyrighted article body (G4, N4) — headline + link + fair-use excerpt only",
      "speaking AS an outlet or AS another actor / impersonation (G9, N5)",
      "an :original first-person claim (G11 — kawaraban is a medium, not a source)",
      "paywalled / proprietary-terminal feeds (G4 — only public facing pages)",
      "live RSS/outlet ingest / live edition publish (G8 — Council Lv6+ + operator)"
    ]
  },
  "cells": [
    { "name": "outlet_ingest", "module": "kawaraban.cells.outlet_ingest", "murakumoNode": "issachar", "phase": "public-facing-page outlet + headline normalization (G4 membrane: refuses full-text / paywall; G5 provenance)", "status": "coded-state-machine", "emitsLexicon": "com.etzhayyim.kawaraban.outlet", "gates": ["G4", "G5", "G8"] },
    { "name": "article_mirror", "module": "kawaraban.cells.article_mirror", "murakumoNode": "asher", "phase": "mirror a real article as observation (G1 no-verdict / G4 link-out / G9 no-speak-as)", "status": "coded-state-machine", "emitsLexicon": "com.etzhayyim.kawaraban.article", "gates": ["G1", "G4", "G9"] },
    { "name": "section_route", "module": "kawaraban.cells.section_route", "murakumoNode": "dan", "phase": "route an article into its 面 (mirror real news-media sectioning); attaches :news.mention edges", "status": "coded-state-machine", "emitsLexicon": "com.etzhayyim.kawaraban.mentionEdge", "gates": ["G2", "G11"] },
    { "name": "actor_project", "module": "kawaraban.cells.actor_project", "murakumoNode": "naphtali", "phase": "THE MEDIUM — project a first-party actor's Datom as-of event into the matching 面 as :article/kind :actor-event (feed-post membrane reuse; G7 member-signed, G11 connective)", "status": "coded-state-machine", "emitsLexicon": "com.etzhayyim.kawaraban.article", "gates": ["G7", "G9", "G11"] },
    { "name": "issue_compose", "module": "kawaraban.cells.issue_compose", "murakumoNode": "benjamin", "phase": "compose a front-面 edition ranked by G2 public-good signals only (recency/section-fit/source-diversity/actor-relevance); G7 unsigned, G8 unpublished, G10 not-final", "status": "coded-state-machine", "emitsLexicon": "com.etzhayyim.kawaraban.issue", "gates": ["G2", "G7", "G8", "G10"] }
  ],
  "lexiconNamespaces": [
    { "id": "com.etzhayyim.kawaraban.outlet", "status": "implemented", "emittedBy": ["outlet_ingest"] },
    { "id": "com.etzhayyim.kawaraban.section", "status": "implemented", "emittedBy": ["section_route"] },
    { "id": "com.etzhayyim.kawaraban.article", "status": "implemented", "emittedBy": ["article_mirror", "actor_project"] },
    { "id": "com.etzhayyim.kawaraban.mentionEdge", "status": "implemented", "emittedBy": ["section_route", "actor_project"] },
