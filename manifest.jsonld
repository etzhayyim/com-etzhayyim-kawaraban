  "murakumoFleet": {
    "note": "5 Pregel cells placed as k3s DaemonSets across the 12-tribe Murakumo fleet (ADR-2605232100). Inference (summary/translation) is Murakumo-only via LiteLLM 127.0.0.1:4000 (G6, ADR-2605215000).",
    "placement": [
      { "cell": "outlet_ingest", "node": "issachar" },
