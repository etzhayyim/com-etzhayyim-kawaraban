    { "phase": "R2", "date": "post-R1", "scope": "Standing news medium feeding the etzhayyim public timeline; cross-actor story clustering (an event surfaced by danjo/watari/watatsuna/mitooshi composed into one 面 with all mention edges); kami-engine 面-layout WASM render on /apps.", "gate": "Future ADR + Council Lv6+ + operator" }
  ],
