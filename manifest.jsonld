    { "id": "com.etzhayyim.kawaraban.kawarabanReview", "status": "implemented", "emittedBy": ["Council attestation flow (Lv6+; never authorizes an ad, a verdict, or a reader profile)"] }
  ],
  "constitutionalGates": {
    "description": "11 immutable gates per ADR-2606061900. G1 (mirror-not-adjudicator) + G2 (no-ads/no-engagement-rank) + G11 (connective-by-construction) are the structural anchors. Each gate lives in THREE places: schema :db/allowed/enum + lexicon const/enum + Python ValueError/refusal.",
    "gates": {
      "G1": "Mirror-not-adjudicator — :article/verdict + :article/truth-rating :db/allowed [false]; records what an outlet published, never rules truth (ake/danjo boundary)",
      "G2": "No-ads / no-engagement-rank — :news.rank/signal excludes :paid-placement/:sponsored/:engagement/:dwell-time (Charter §1.13 + Charter-Rider §2)",
      "G3": "No-reader-surveillance — no :reader entity; :article/personalized-for :db/allowed [false]; the 面 is identical for all (watari person-exclusion)",
      "G4": "Copyright / link-out — :article/full-text :db/allowed [false]; headline + canonical :url + bounded fair-use :excerpt + :outlet only (kanjo §2(c))",
      "G5": "Source-provenance-honest — :mirror requires :outlet + :url + :as-of; :representative seed flagged; fabricated coverage refused (watari freshness)",
      "G6": "Murakumo-only — any summarization/translation via LiteLLM 127.0.0.1:4000 (ADR-2605215000)",
      "G7": "No-server-key — actor-event projection + issue publication member/operator-signed; :server-held-key const false (ADR-2605231525)",
      "G8": "Outward-gated — live outlet/RSS ingest + live publish = Council Lv6+ + operator (watari/mitooshi G10)",
      "G9": "Mirror-not-impersonation — :article/speak-as :db/allowed [false]; mirrors outlets AND actors as observations, never speaks AS them (ADR-2606042330)",
      "G10": "Non-eschatological as-of — :news.issue/final :db/allowed [false]; append-only edition trail (非終末論)",
      "G11": "Connective-by-construction (the MEDIUM gate) — every article is :mirror (real outlet) OR :actor-event (projected first-party Datom); :original is unrepresentable; the article×mention×面 graph is the actor-to-actor wire"
    }
  },
  "nonGoals": {
    "description": "6 explicitly excluded scopes",
    "goals": {
      "N1": "NOT a fact-checker / truth adjudicator — no verdict, no rating (G1; ake/danjo own correction & discrepancy)",
      "N2": "NOT an ad-funded / engagement-optimized feed — no paid placement, no addictive ranking (G2)",
      "N3": "NOT a personalized feed — no reader profile, no behavioral recommendation, no surveillance (G3)",
      "N4": "NOT a content republisher — headline + link + fair-use excerpt only, never the full body (G4)",
      "N5": "NOT an impersonator — never posts AS an outlet or AS another actor (G9)",
      "N6": "NOT a primary source — kawaraban authors no original first-person claim; it mirrors and wires (G11; kataribe is the primary voice)"
    }
  },
  "roadmap": [
